{
  "agents": {
    "defaults": {
      "model": {
        "primary": "openai-codex/gpt-5.3-codex-spark",
        "fallbacks": [
          "openai-codex/gpt-5.3-codex",
          "minimax-portal/MiniMax-M2.5"
        ]
      },
      "compaction": {
        "mode": "safeguard"
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      },
      "sandbox": {
        "mode": "non-main",
        "workspaceAccess": "none"
      }
    }
  },
  "tools": {
    "profile": "minimal",
    "alsoAllow": [
      "web_search",
      "web_fetch",
      "second-opinion-tool_agent_second_opinion",
      "second-opinion-tool_rate_limit_status",
      "second-opinion-tool_health-check"
    ],
    "deny": [
      "read",
      "write",
      "edit",
      "apply_patch",
      "exec",
      "bash",
      "process",
      "browser",
      "canvas",
      "nodes",
      "cron",
      "gateway",
      "discord",
      "sessions_send",
      "sessions_spawn"
    ],
    "web": {
      "search": {
        "enabled": true,
        "provider": "perplexity",
        "maxResults": 8,
        "perplexity": {
          "apiKey": "${PERPLEXITY_API_KEY}"
        }
      }
    }
  },
  "messages": {
    "responsePrefix": "[Consensus] ",
    "ackReaction": "eyes",
    "ackReactionScope": "group-mentions"
  },
  "commands": {
    "native": true,
    "nativeSkills": "auto"
  },
  "channels": {
    "discord": {
      "enabled": true,
      "commands": {
        "native": true
      },
      "token": "${DISCORD_BOT_TOKEN}",
      "groupPolicy": "allowlist",
      "replyToMode": "off",
      "guilds": {
        "YOUR_GUILD_ID": {
          "requireMention": true
        }
      }
    }
  },
  "gateway": {
    "port": 18790,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    },
    "remote": {
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    }
  },
  "plugins": {
    "entries": {
      "openclaw-mcp-adapter": {
        "enabled": true,
        "config": {
          "servers": [
            {
              "name": "second-opinion-tool",
              "transport": "http",
              "url": "${SECOND_OPINION_MCP_URL}",
              "headers": {
                "Accept": "application/json, text/event-stream",
                "Authorization": "Bearer ${SECOND_OPINION_MCP_TOKEN}"
              }
            }
          ],
          "toolPrefix": true
        }
      },
      "discord": {
        "enabled": true
      },
      "minimax-portal-auth": {
        "enabled": false
      }
    }
  },
  "models": {
    "providers": {
      "minimax-portal": {
        "baseUrl": "https://api.minimax.io/anthropic",
        "apiKey": "minimax-oauth",
        "api": "anthropic-messages",
        "models": [
          {
            "id": "MiniMax-M2.1",
            "name": "MiniMax M2.1",
            "reasoning": false,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 200000,
            "maxTokens": 8192
          },
          {
            "id": "MiniMax-M2.5",
            "name": "MiniMax M2.5",
            "reasoning": true,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 200000,
            "maxTokens": 8192
          }
        ]
      }
    }
  }
}
