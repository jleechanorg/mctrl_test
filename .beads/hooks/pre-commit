#!/usr/bin/env sh
# bd-shim v2 + gitleaks secret scanner
# bd-hooks-version: 0.56.1

# --- gitleaks: scan staged files for secrets ---
if command -v gitleaks >/dev/null 2>&1; then
    gitleaks protect --staged --config .gitleaks.toml 2>/dev/null \
        || gitleaks protect --staged 2>&1
    if [ $? -ne 0 ]; then
        echo "❌ gitleaks detected secrets in staged files. Commit blocked." >&2
        echo "   Fix leaks, then re-stage. To skip: git commit --no-verify" >&2
        exit 1
    fi
else
    echo "Warning: gitleaks not found — secret scanning skipped." >&2
    echo "  Install: brew install gitleaks  or  https://github.com/gitleaks/gitleaks" >&2
fi

# --- bd (beads) pre-commit hook — thin shim ---
# Delegates to 'bd hooks run pre-commit' which contains the actual hook
# logic. This pattern ensures hook behavior is always in sync with the
# installed bd version — no manual updates needed.

if ! command -v bd >/dev/null 2>&1; then
    echo "Warning: bd command not found in PATH, skipping bd pre-commit hook" >&2
    exit 0
fi

exec bd hooks run pre-commit "$@"
