[0.267649, "o", "\u001b[1mdiff --git a/largest_rectangle_histogram.py b/largest_rectangle_histogram.py\u001b[m\r\n\u001b[1mnew file mode 100644\u001b[m\r\n\u001b[1mindex 0000000..69d7a12\u001b[m\r\n\u001b[1m--- /dev/null\u001b[m\r\n\u001b[1m+++ b/largest_rectangle_histogram.py\u001b[m\r\n\u001b[36m@@ -0,0 +1,106 @@\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m\"\"\"\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32mLeetCode 84: Largest Rectangle in Histogram\u001b[m\r\n\u001b[32m+\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32mGiven an array of heights representing a histogram, find the largest rectangle\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32mthat can be formed in the histogram.\u001b[m\r\n\u001b[32m+\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32mApproach: Monotonic Stack\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m- Use a monotonic increasing stack to track bar indices\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m- When a shorter bar is encountered, pop taller bars and calculate areas\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m- Add a sentinel bar (height 0) at the end to flush the stack\u001b[m\r\n\u001b[32m+\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32mTime Complexity: O(n) - each bar is pushed and popped at most once\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32mSpace Complexity: O(n) - for the stack\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m\"\"\"\u001b[m\r\n\u001b[32m+\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32mfrom typing import List\u001b[m\r\n\u001b[32m+\u001b[m\r"]
[0.267737, "o", "\r\n\u001b[32m+\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32mdef largest_rectangle_area(heights: List[int]) -> int:\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m    \"\"\"\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m    Find the largest rectangle area in a histogram.\u001b[m\r\n\u001b[32m+\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m    Args:\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m        heights: List of non-negative integers representing bar heights\u001b[m\r\n\u001b[32m+\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m    Returns:\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m        The largest rectangular area that can be formed\u001b[m\r\n\u001b[32m+\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m    Example:\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m        >>> largest_rectangle_area([2, 1, 5, 6, 2, 3])\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m        10\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m    \"\"\"\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m    if not heights:\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m        return 0\u001b[m\r\n\u001b[32m+\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m    stack: List[int] = []  # stores indices\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m    max_area = 0\u001b[m\r\n\u001b[32m+\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m    # Add sentinel to flush remaining bars in stack\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m    for i, height in enumerate(heights + [0]):\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m        # While current bar is shorter than stack top, calculate areas\u001b[m\r\n\u001b[32m+\u001b[m\u001b["]
[0.26779, "o", "32m        while stack and heights[stack[-1]] > height:\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m            h = heights[stack.pop()]\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m            # Width extends from after the bar at stack top to current index\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m            w = i if not stack else i - stack[-1] - 1\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m            max_area = max(max_area, h * w)\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m        stack.append(i)\u001b[m\r\n\u001b[32m+\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m    return max_area\u001b[m\r\n\u001b[32m+\u001b[m\r\n\u001b[32m+\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32mdef largest_rectangle_area_brute(heights: List[int]) -> int:\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m    \"\"\"\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m    Brute force solution for comparison - O(n^2) time.\u001b[m\r\n\u001b[32m+\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m    For each bar, expand left and right to find the maximum width\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m    where this bar is the shortest.\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m    \"\"\"\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m    if not heights:\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m        return 0\u001b[m\r\n\u001b[32m+\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m    max_area = 0\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m    n = len(heights)\u001b[m\r\n\u001b[32m+\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m    for i in range(n):\u001b[m\r\n\u001b[32"]
[0.267807, "o", "m+\u001b[m\u001b[32m        # Expand left\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m        left = i\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m        while left > 0 and heights[left - 1] >= heights[i]:\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m            left -= 1\u001b[m\r\n\u001b[32m+\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m        # Expand right\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m        right = i\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m        while right < n - 1 and heights[right + 1] >= heights[i]:\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m            right += 1\u001b[m\r\n\u001b[32m+\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m        width = right - left + 1\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m        max_area = max(max_area, heights[i] * width)\u001b[m\r\n\u001b[32m+\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m    return max_area\u001b[m\r\n\u001b[32m+\u001b[m\r\n\u001b[32m+\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32mif __name__ == \"__main__\":\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m    # Test cases\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m    test_cases = [\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m        ([2, 1, 5, 6, 2, 3], 10),  # Expected: 10\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m        ([2, 4], 4),               # Expected: 4\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m        ([1], 1),                  # Expected: 1\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m        ([1, 1], 2),               # Expected: 2 (both bars height 1, width 2)\u001b[m\r\n\u001b["]
[0.267881, "o", "32m+\u001b[m\u001b[32m        ([0, 0], 0),               # Expected: 0\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m        ([2, 1, 2], 3),           # Expected: 3\u001b[m\r\n"]
[0.267946, "o", "\u001b[32m+\u001b[m\u001b[32m        ([1, 2, 3, 4, 5], 9),     # Expected: 9\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m        ([5, 4, 3, 2, 1], 9),     # Expected: 9\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m    ]\u001b[m\r\n\u001b[32m+\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m    print(\"Testing largest_rectangle_area:\")\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m    for heights, expected in test_cases:\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m        result = largest_rectangle_area(heights)\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m        status = \"✓\" if result == expected else \"✗\"\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m        print(f\"  {status} heights={heights}, expected={expected}, got={result}\")\u001b[m\r\n\u001b[32m+\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m    print(\"\\nComparing with brute force:\")\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m    for heights, expected in test_cases:\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m        opt = largest_rectangle_area(heights)\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m        brute = largest_rectangle_area_brute(heights)\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m        match = \"✓\" if opt == brute else \"✗\"\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m        print(f\"  {match} Optimized={opt}, Brute={brute}\")\u001b[m\r\n"]
