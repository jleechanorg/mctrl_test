# jleechanclaw + Mission Control Configuration
# Copy this to .env and fill in real values for local development.
# IMPORTANT: Never commit .env with real credentials!

# =============================================================================
# Mission Control API
# =============================================================================

# Base URL for Mission Control API (e.g., http://localhost:8000)
MISSION_CONTROL_BASE_URL=http://localhost:8000

# Bearer token for Mission Control API authentication
MISSION_CONTROL_TOKEN=your-local-auth-token-here

# UUID of the ops board in Mission Control
MISSION_CONTROL_BOARD_ID=00000000-0000-0000-0000-000000000000

# Full URL for webhook ingestion (used by Phase 1 webhook bridge)
MISSION_CONTROL_WEBHOOK_URL=http://localhost:8000/api/v1/webhooks/ingest

# =============================================================================
# Database
# =============================================================================

# PostgreSQL connection string (used by docker-compose services)
# NOTE: Use service name 'db' (not 'localhost') so backend/worker containers can reach Postgres
DATABASE_URL=postgresql://openclaw:openclaw@db:5432/openclaw

# Database credentials (used by docker-compose)
DB_USER=openclaw
DB_PASSWORD=openclaw
DB_NAME=openclaw

# Auto-run database migrations on startup (true/false)
DB_AUTO_MIGRATE=true

# =============================================================================
# Redis / RQ (Task Queue)
# =============================================================================

# Redis connection URL for RQ worker
# NOTE: Use service name 'redis' (not 'localhost') inside docker-compose containers
RQ_REDIS_URL=redis://redis:6379/0

# Name of the RQ queue for webhook processing
RQ_QUEUE_NAME=webhooks

# Seconds to wait before dispatching duplicate webhooks (rate limiting)
RQ_DISPATCH_THROTTLE_SECONDS=60

# Maximum number of retry attempts for failed webhook dispatch
RQ_DISPATCH_MAX_RETRIES=3

# =============================================================================
# API Server
# =============================================================================

# CORS origins (comma-separated list of allowed domains)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Local auth token for development (same as MISSION_CONTROL_TOKEN)
LOCAL_AUTH_TOKEN=your-local-auth-token-here
